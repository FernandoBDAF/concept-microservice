# Worker Service Environment Configuration
# Copy this file to .env and update the values for your environment

# RabbitMQ Connection Settings
# Required: RabbitMQ server hostname or IP address
RABBITMQ_HOST=localhost

# Required: RabbitMQ server port (default: 5672)
RABBITMQ_PORT=5672

# Required: RabbitMQ username for authentication
RABBITMQ_USER=guest

# Required: RabbitMQ password for authentication
RABBITMQ_PASSWORD=guest

# Optional: RabbitMQ virtual host (default: /)
RABBITMQ_VHOST=/

# Service Configuration
# Optional: Log level (debug, info, warn, error) (default: info)
LOG_LEVEL=info

# Optional: HTTP server port for health checks (default: 8080)
HTTP_PORT=8080

# Optional: Enable metrics collection (default: true)
METRICS_ENABLED=true

# RabbitMQ Queue Configuration (handled by common package)
# These are typically set by the common queue package defaults
# but can be overridden if needed:

# Optional: Queue prefetch count (default: 1)
# QUEUE_PREFETCH_COUNT=1

# Optional: Maximum connection retry attempts (default: 3)
# QUEUE_MAX_RETRIES=3

# Optional: Retry delay between connection attempts (default: 5s)
# QUEUE_RETRY_DELAY=5s

# Optional: Connection heartbeat interval (default: 10s)
# QUEUE_HEARTBEAT=10s

# Development/Testing Settings
# Optional: Queue name override (for testing different queues)
# QUEUE_NAME=profile-processing

# Optional: Exchange name override (for testing different exchanges)
# EXCHANGE_NAME=profile-tasks

# Optional: Routing key override (for testing different routing)
# ROUTING_KEY=profile.task

# Kubernetes/Production Settings
# When running in Kubernetes, these are typically provided via ConfigMaps/Secrets:
# RABBITMQ_HOST=rabbitmq-service
# RABBITMQ_USER=<from-secret>
# RABBITMQ_PASSWORD=<from-secret>

# Example Production Configuration:
# RABBITMQ_HOST=rabbitmq-cluster.messaging.svc.cluster.local
# RABBITMQ_PORT=5672
# RABBITMQ_USER=worker-service-user
# RABBITMQ_PASSWORD=<secure-password>
# LOG_LEVEL=info
# METRICS_ENABLED=true
