{
  "dashboard": {
    "id": null,
    "title": "Multi-Worker Architecture Dashboard",
    "tags": ["workers", "email", "image", "rabbitmq"],
    "style": "dark",
    "timezone": "browser",
    "editable": true,
    "hideControls": false,
    "graphTooltip": 1,
    "panels": [
      {
        "id": 1,
        "title": "Worker Health Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"email-worker\"}",
            "legendFormat": "Email Worker"
          },
          {
            "expr": "up{job=\"image-worker\"}",
            "legendFormat": "Image Worker"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "horizontal",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          }
        }
      },
      {
        "id": 2,
        "title": "Message Processing Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(email_processing_success_total[5m])",
            "legendFormat": "Email Success Rate"
          },
          {
            "expr": "rate(email_processing_errors_total[5m])",
            "legendFormat": "Email Error Rate"
          },
          {
            "expr": "rate(image_processing_success_total[5m])",
            "legendFormat": "Image Success Rate"
          },
          {
            "expr": "rate(image_processing_errors_total[5m])",
            "legendFormat": "Image Error Rate"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "yAxes": [
          {
            "label": "messages/sec",
            "min": 0
          }
        ]
      },
      {
        "id": 3,
        "title": "Processing Latency (95th percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, email_processing_time_seconds)",
            "legendFormat": "Email P95 Latency"
          },
          {
            "expr": "histogram_quantile(0.95, image_processing_time_seconds)",
            "legendFormat": "Image P95 Latency"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "yAxes": [
          {
            "label": "seconds",
            "min": 0
          }
        ]
      },
      {
        "id": 4,
        "title": "Messages In Flight",
        "type": "graph",
        "targets": [
          {
            "expr": "email_messages_in_flight",
            "legendFormat": "Email Messages"
          },
          {
            "expr": "image_messages_in_flight",
            "legendFormat": "Image Messages"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "yAxes": [
          {
            "label": "messages",
            "min": 0
          }
        ]
      },
      {
        "id": 5,
        "title": "Worker Pod Count",
        "type": "graph",
        "targets": [
          {
            "expr": "kube_deployment_status_replicas{deployment=\"email-worker\"}",
            "legendFormat": "Email Worker Pods"
          },
          {
            "expr": "kube_deployment_status_replicas{deployment=\"image-worker\"}",
            "legendFormat": "Image Worker Pods"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "yAxes": [
          {
            "label": "pods",
            "min": 0
          }
        ]
      },
      {
        "id": 6,
        "title": "CPU Usage by Worker",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{pod=~\"email-worker-.*\"}[5m])",
            "legendFormat": "Email Worker CPU"
          },
          {
            "expr": "rate(container_cpu_usage_seconds_total{pod=~\"image-worker-.*\"}[5m])",
            "legendFormat": "Image Worker CPU"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "yAxes": [
          {
            "label": "CPU cores",
            "min": 0,
            "max": 1
          }
        ]
      },
      {
        "id": 7,
        "title": "Memory Usage by Worker",
        "type": "graph",
        "targets": [
          {
            "expr": "container_memory_usage_bytes{pod=~\"email-worker-.*\"} / 1024 / 1024",
            "legendFormat": "Email Worker Memory (MB)"
          },
          {
            "expr": "container_memory_usage_bytes{pod=~\"image-worker-.*\"} / 1024 / 1024",
            "legendFormat": "Image Worker Memory (MB)"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "yAxes": [
          {
            "label": "MB",
            "min": 0
          }
        ]
      },
      {
        "id": 8,
        "title": "RabbitMQ Queue Depth",
        "type": "graph",
        "targets": [
          {
            "expr": "rabbitmq_queue_messages{queue=\"email-processing\"}",
            "legendFormat": "Email Queue"
          },
          {
            "expr": "rabbitmq_queue_messages{queue=\"image-processing\"}",
            "legendFormat": "Image Queue"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "yAxes": [
          {
            "label": "messages",
            "min": 0
          }
        ]
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "timepicker": {},
    "templating": { "list": [] },
    "annotations": { "list": [] },
    "refresh": "10s",
    "schemaVersion": 30,
    "version": 1,
    "links": []
  }
}
