# Copy to .env and adjust. docker-compose.yml reads this automatically.
# All values below are local-development defaults — never use in production.

# auth-service JWT signing secret (min 32 chars)
JWT_SECRET=local-dev-jwt-secret-change-me-32chars!!

# Log verbosity for auth-service (fatal|error|warn|info|debug|trace)
LOG_LEVEL=info

# Auth rate limits (lab-sized defaults; lower TOKEN_VALIDATION_RATE_LIMIT_MAX
# to 100 to reproduce the breaker-outage incident — EXPERIMENTS.md EXP-08)
# RATE_LIMIT_MAX_REQUESTS=100000
# TOKEN_VALIDATION_RATE_LIMIT_MAX=100000

# Optional: enable the real GraphRAG LLM pipeline in graphrag-service
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
